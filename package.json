{
  "name": "opencode-zen-provider",
  "publisher": "HidenobuNagai",
  "displayName": "OpenCode Zen Provider for Copilot Chat",
  "description": "OpenCode Zen chat provider for VS Code Copilot Chat",
  "version": "0.1.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hidenobunagai/opencode-zen-provider"
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1A1A2E",
    "theme": "dark"
  },
  "keywords": [
    "copilot",
    "opencode",
    "zen",
    "chat",
    "gpt",
    "claude",
    "gemini",
    "qwen",
    "minimax"
  ],
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "opencode-zen",
        "displayName": "OpenCode Zen",
        "configuration": {
          "type": "object",
          "properties": {
            "apiKey": {
              "type": "string",
              "secret": true,
              "description": "API key for OpenCode Zen",
              "title": "API Key"
            }
          },
          "required": [
            "apiKey"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "opencode-zen.manage",
        "title": "Manage OpenCode Zen API Key",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.toggleDebugLogging",
        "title": "Toggle Debug Logging",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.openDebugLog",
        "title": "Open Debug Log",
        "category": "OpenCode Zen"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "package:vsix": "bun run compile && vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "1.104.0",
    "@vscode/vsce": "^3.9.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.0.0",
    "jest-util": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.22"
  }
}
