{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "rootDir": "src",
    "outDir": "out",
    "lib": ["ES2020"],
    "types": ["node", "jest"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "out", "tests"]
}
